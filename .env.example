# Backend
API_PORT=4000
DATABASE_URL=postgres://user:password@localhost:5432/allowancebuddy
JWT_SECRET=replace-with-dev-secret

# Vision service
VISION_PORT=5001
VISION_CAMERA_DEVICE=0
DETECTION_WINDOW_SECONDS=30
PHONE_DEDUCTION_CENTS=25
BOOK_REWARD_CENTS=25

# Finance engine
FINANCE_PORT=5002
DEFAULT_ALLOWANCE_CENTS=500

# Voice service (ElevenLabs)
VOICE_PORT=5003
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_AGENT_ID=replace-with-elevenlabs-agent-id
ELEVENLABS_VOICE_ID=replace-with-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_WEBHOOK_SECRET=replace-with-webhook-secret
VOICE_DEFAULT_LANGUAGE=en
VOICE_MAX_RESPONSE_SECONDS=20
